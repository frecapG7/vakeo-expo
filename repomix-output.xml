const showDay = (previous?: Event, current?: Event) => {
    if (!current?.startDate)
        return false;
    if (!previous?.startDate)
        return true;
    return !dayjs(previous.startDate).isSame(dayjs(current.startDate), 'day');

}



const typeFilters = [
    {
        value: "",
        label: "Tous"
    },
    {
        value: "ACTIVITY",
        icon: "flame",
        label: "Activité"
    },
