}

export const useGetGoodsCount = (tripId: any, params?: any) => {
    return useQuery<ICount, Error>({
        queryKey: ["trips", tripId, "goods", "count", params],
        queryFn: () => getCount(tripId, params),
        enabled: !!tripId
    })
}


