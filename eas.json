{
  "cli": {
    "version": ">= 16.13.3",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "ios-simulator": {
      "extends": "development",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "autoIncrement": true,
      "distribution": "internal",
      "environment": "preview",
      "credentialsSource": "remote"
    },
    "production": {
      "environment": "production",
      "credentialsSource": "remote",
      "app.json": {
        "expo": {
          "name": "olyne",
          "slug": "olyne",
          "ios": {
            "bundleIdentifier": "com.frecapg7.olyne"
          },
          "android": {
            "package": "com.frecapg7.olyne"
          }
        }
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./service-account.json"
      },
      "ios": {
        "ascApiKeyPath": "./asc-api-key.json"
      }
    }
  }
}
