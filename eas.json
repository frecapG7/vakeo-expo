{
  "cli": {
    "version": ">= 16.13.3",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_ENVIRONMENT": "development"
      }
    },
    "ios-simulator": {
      "extends": "development",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "autoIncrement": true,
      "distribution": "internal",
      "environment": "preview",
      "credentialsSource": "remote",
      "env": {
        "APP_ENVIRONMENT": "preview"
      }
    },
    "production": {
      "environment": "production",
      "credentialsSource": "remote",
      "env": {
        "APP_ENVIRONMENT": "production"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./service-account.json"
      },
      "ios": {
        "ascApiKeyPath": "./asc-api-key.json",
        "ascApiKeyId": "H4WX38MS9P",
        "ascApiKeyIssuerId": "c44dbaa3-0315-47ef-bf05-0d90cc340ba2",
        "ascAppId": "6788799778"
      }
    }
  }
}
